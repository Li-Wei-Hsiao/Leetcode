bool isValid(char* s) {
    if (strlen(s) % 2 != 0) return false;

    char stack[strlen(s) / 2 + 1];
    int top = -1;

    for (int i = 0; i < strlen(s); i ++) {
        if (s[i] == '(' || s[i] == '[' || s[i] == '{') {
            if (top == sizeof(stack) - 1) return false;
            stack[++top] = s[i];
        } else {
            if (top < 0) return false;
            switch (s[i]) {
                case ')': 
                    if (stack[top] != '(') return false;
                    else top --;
                    break;

                case ']': 
                    if (stack[top] != '[') return false;
                    else top --;
                    break;

                case '}': 
                    if (stack[top] != '{') return false;
                    else top --;
                    break;
            }
        }
    }
    if (top != -1) return false;
    return true;
}