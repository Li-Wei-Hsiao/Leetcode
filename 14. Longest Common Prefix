char* longestCommonPrefix(char** strs, int strsSize) {
    if (strsSize == 1) return strs[0];

    int i = 0;
    for (i; i < strlen(strs[0]); i ++) {
        char temp = strs[0][i];
        //printf("temp = %c\n", temp);
        for (int j = 1; j < strsSize; j ++) {
            if (strs[j][i] != temp) {
                char *ans = (char *)malloc((i + 1) * sizeof(char));
                for (int k = 0; k < i; k ++) ans[k] = strs[0][k];
                ans[i] = '\0';
                //printf("i+1 = %d\n", i + 1);
                return ans;
            }
        }
    }

    char *ans = (char *)malloc((i + 1) * sizeof(char));
    ans = strs[0];
    ans[strlen(ans)] = '\0';
    return ans;
}