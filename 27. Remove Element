int removeElement(int* nums, int numsSize, int val) {
    if (numsSize == 0) {
        return 0;
    }

    uint8_t size = 0;
    for (uint8_t i = 0; i < numsSize; i ++) {
        if (nums[i] == val) {
            for (int j = i; j < numsSize; j ++) {
                if (nums[j] != val) {
                    //printf("nums[j] = %d\n", nums[j]);
                    //printf("switch %d(%d) <-> %d(%d)\n\n", i, nums[i], j, nums[j]);
                    int temp = nums[i];
                    nums[i] = nums[j];
                    nums[j] = temp;
                    size ++;
                    break;
                }
            }
        } else size ++;
    }
    //printf("annwer = %d\n", size);
    return size;
}